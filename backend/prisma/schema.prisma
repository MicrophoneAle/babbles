generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Entry {
  id        Int      @id @default(autoincrement())
  date      DateTime @unique @db.Date
  content   Json
  plainText String
  wordCount Int      @default(0)
  tags      Tag[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  entries Entry[]
}
